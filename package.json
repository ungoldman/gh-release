{
  "name": "gh-release",
  "description": "Create a GitHub Release for a Node package",
  "version": "8.0.0",
  "author": "Nate Goldman <ungoldman@gmail.com> (https://ungoldman.com)",
  "bin": {
    "gh-release": "./dist/bin.js"
  },
  "bugs": {
    "url": "https://github.com/ungoldman/gh-release/issues"
  },
  "contributors": [
    "Nate Goldman <ungoldman@gmail.com>",
    "Bret Comnes <bcomnes@gmail.com>",
    "Paul C Pederson <paul.c.pederson@gmail.com>",
    "John Gravois <me@johngravois.com>",
    "Hawken MacKay Rives <hawkrives@gmail.com>",
    "Henry Huang <h1886@outlook.com>",
    "Zeke Sikelianos <zeke@sikelianos.com>",
    "Belikin Roman <roman.sstu@gmail.com>",
    "Ted Janeczko <tjaneczko@brightcove.com>"
  ],
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "changelog-parser": "^4.1.0",
    "gh-release-assets": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.19.21",
    "fast-check": "^4.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/ungoldman/gh-release",
  "keywords": [
    "changelog",
    "github",
    "release",
    "semver",
    "tag"
  ],
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ungoldman/gh-release.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "coverage": "npm run build && node --test --import=tsx --experimental-test-coverage --test-coverage-exclude=\"test/**\" --test-coverage-exclude=\"dist/**\" --test-coverage-exclude=\"src/bin.ts\" --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 test/*.test.ts",
    "format": "biome check --write .",
    "lint": "biome check .",
    "prebuild": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "npm run lint && npm run typecheck && npm run build && node --test --import=tsx test/*.test.ts",
    "typecheck": "tsc"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts"
}
